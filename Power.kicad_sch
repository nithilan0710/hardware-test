	(text "1S 350mah\n3.3V min.-4.2V max."
		(exclude_from_sim no)
		(at 26.162 70.612 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "dfa7a195-9dab-40c9-94f4-b8ec9dca9345")
	)
	(text "1) CC1 & CC2 not used. So it is connected to Gnd as mentioned in 6.1.3 USB port detection at page 20&21 in Ref.1\n\n2) Battery NTC not used. So it is connected to ground through 10K resistor\n\n3) To make VOUT1 = 1.8V, VSET1 connected to Resistor 47K as mentioned in \"Table 18: Default VOUT1 using an external resistor\" at page 47 Ref.1\n\n4) To make VOUT2 = 3.3V, VSET2 connected to Resistor 270K as mentioned in \"Table 19: Default VOUT2 using an external resistor\" at page 47 Ref.1\n"
		(exclude_from_sim no)
		(at 14.732 161.29 0)
		(effects
			(font
				(face "Times New Roman")
				(size 1.8 1.8)
				(color 18 22 255 1)
			)
			(justify left)
		)
		(uuid "e3a61e1f-aa28-4fac-ae45-e485f33a32ce")
	)
